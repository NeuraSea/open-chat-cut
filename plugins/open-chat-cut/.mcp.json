{
  "mcpServers": {
    "openchatcut": {
      "title": "OpenChatCut",
      "description": "Revision-safe access to the local OpenChatCut daemon.",
      "icons": [
        {
          "src": "./assets/icon.svg",
          "mimeType": "image/svg+xml",
          "sizes": ["24x24"]
        }
      ],
      "cwd": ".",
      "command": "node",
      "args": ["./mcp/server.mjs", "--stdio"]
    }
  }
}
